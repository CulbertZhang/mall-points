generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MemberLevel {
  id              BigInt   @id @default(autoincrement())
  levelCode       String   @unique @map("level_code") @db.VarChar(20)
  levelName       String   @map("level_name") @db.VarChar(50)
  levelRank       Int      @unique @map("level_rank")
  minGrowthValue  Int      @default(0) @map("min_growth_value")
  maxGrowthValue  Int      @default(0) @map("max_growth_value")
  iconUrl         String?  @map("icon_url") @db.VarChar(500)
  discountRate    Decimal  @default(1.00) @map("discount_rate") @db.Decimal(3, 2)
  benefits        Json     @default("{}")
  pointsMultiplier Decimal @default(1.00) @map("points_multiplier") @db.Decimal(4, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  status          Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("member_levels")
}

model User {
  id              BigInt    @id @default(autoincrement())
  username        String    @unique @db.VarChar(50)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  nickname        String?   @db.VarChar(50)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  phone           String?   @unique @db.VarChar(20)
  email           String?   @unique @db.VarChar(100)
  gender          Int       @default(0)
  birthday        DateTime? @db.Date
  memberLevelId   BigInt?   @map("member_level_id")
  growthValue     Int       @default(0) @map("growth_value")
  pointsBalance   Int       @default(0) @map("points_balance")
  totalPointsEarned Int     @default(0) @map("total_points_earned")
  status          Int       @default(1)
  lastLoginAt     DateTime? @map("last_login_at")
  lastLoginIp     String?   @map("last_login_ip") @db.VarChar(50)
  sourceChannel   String?   @map("source_channel") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  memberLevel       MemberLevel?        @relation(fields: [memberLevelId], references: [id])
  shoppingCartItems ShoppingCart[]
  orders            Order[]
  addresses         UserAddress[]
  signInRecords     SignInRecord[]
  pointsAccount     PointsAccount?

  @@index([memberLevelId])
  @@index([status])
  @@map("users")
}

model Category {
  id            BigInt    @id @default(autoincrement())
  parentId      BigInt    @default(0) @map("parent_id")
  name          String    @db.VarChar(100)
  iconUrl       String?   @map("icon_url") @db.VarChar(500)
  imageUrl      String?   @map("image_url") @db.VarChar(500)
  level         Int       @default(1)
  path          String    @default("") @db.VarChar(500)
  isLeaf        Boolean   @default(true) @map("is_leaf")
  sortOrder     Int       @default(0) @map("sort_order")
  isRecommended Boolean   @default(false) @map("is_recommended")
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@index([parentId])
  @@index([status, sortOrder])
  @@map("categories")
}

model Product {
  id            BigInt    @id @default(autoincrement())
  spuCode       String    @unique @map("spu_code") @db.VarChar(50)
  categoryId    BigInt    @map("category_id")
  name          String    @db.VarChar(200)
  subtitle      String?   @db.VarChar(200)
  keywords      String?   @db.VarChar(500)
  mainImageUrl  String    @map("main_image_url") @db.VarChar(500)
  description   String?   @db.Text
  detailHtml    String?   @map("detail_html") @db.Text
  minPrice      Decimal   @default(0) @map("min_price") @db.Decimal(12, 2)
  maxPrice      Decimal   @default(0) @map("max_price") @db.Decimal(12, 2)
  totalStock    Int       @default(0) @map("total_stock")
  salesCount    Int       @default(0) @map("sales_count")
  unit          String    @default("件") @db.VarChar(20)
  tags          Json      @default("[]")
  onsaleStatus  Int       @default(0) @map("onsale_status")
  isRecommended Boolean   @default(false) @map("is_recommended")
  isNew         Boolean   @default(false) @map("is_new")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  category     Category       @relation(fields: [categoryId], references: [id])
  skus         ProductSku[]
  images       ProductImage[]
  shoppingCart ShoppingCart[]

  @@index([categoryId])
  @@index([onsaleStatus])
  @@map("products")
}

model ProductSku {
  id            BigInt    @id @default(autoincrement())
  productId     BigInt    @map("product_id")
  skuCode       String    @unique @map("sku_code") @db.VarChar(100)
  skuName       String?   @map("sku_name") @db.VarChar(200)
  specInfo      Json      @default("{}") @map("spec_info")
  imageUrl      String?   @map("image_url") @db.VarChar(500)
  price         Decimal   @map("price") @db.Decimal(12, 2)
  originalPrice Decimal?  @map("original_price") @db.Decimal(12, 2)
  stock         Int       @default(0)
  lockedStock   Int       @default(0) @map("locked_stock")
  weight        Int       @default(0)
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  product      Product        @relation(fields: [productId], references: [id])
  shoppingCart ShoppingCart[]
  orderItems   OrderItem[]

  @@index([productId])
  @@map("product_skus")
}

model ProductImage {
  id        BigInt   @id @default(autoincrement())
  productId BigInt   @map("product_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_images")
}

model ShoppingCart {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  productId  BigInt   @map("product_id")
  skuId      BigInt   @map("sku_id")
  quantity   Int      @default(1)
  isSelected Boolean  @default(true) @map("is_selected")
  addedPrice Decimal? @map("added_price") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id])
  product Product    @relation(fields: [productId], references: [id])
  sku     ProductSku @relation(fields: [skuId], references: [id])

  @@unique([userId, skuId])
  @@index([userId])
  @@map("shopping_cart")
}

model Order {
  id                   BigInt    @id @default(autoincrement())
  orderNo              String    @unique @map("order_no") @db.VarChar(32)
  userId               BigInt    @map("user_id")
  orderType            Int       @default(1) @map("order_type")
  status               String    @default("pending_pay") @db.VarChar(30)
  totalProductAmount   Decimal   @default(0) @map("total_product_amount") @db.Decimal(12, 2)
  discountAmount       Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  freightAmount        Decimal   @default(0) @map("freight_amount") @db.Decimal(12, 2)
  payAmount            Decimal   @default(0) @map("pay_amount") @db.Decimal(12, 2)
  pointsUsed           Int       @default(0) @map("points_used")
  pointsEarned         Int       @default(0) @map("points_earned")
  growthValueEarned    Int       @default(0) @map("growth_value_earned")
  couponDiscount       Decimal   @default(0) @map("coupon_discount") @db.Decimal(12, 2)
  memberDiscount       Decimal   @default(0) @map("member_discount") @db.Decimal(12, 2)
  paymentMethod        String?   @map("payment_method") @db.VarChar(30)
  paymentNo            String?   @map("payment_no") @db.VarChar(64)
  paymentTime          DateTime? @map("payment_time")
  shippingReceiverName String?   @map("shipping_receiver_name") @db.VarChar(50)
  shippingReceiverPhone String?  @map("shipping_receiver_phone") @db.VarChar(20)
  shippingProvince     String?   @map("shipping_province") @db.VarChar(50)
  shippingCity         String?   @map("shipping_city") @db.VarChar(50)
  shippingDistrict     String?   @map("shipping_district") @db.VarChar(50)
  shippingDetail       String?   @map("shipping_detail") @db.VarChar(500)
  shippingCompany      String?   @map("shipping_company") @db.VarChar(50)
  shippingNo           String?   @map("shipping_no") @db.VarChar(50)
  shippingTime         DateTime? @map("shipping_time")
  receiveTime          DateTime? @map("receive_time")
  cancelReason         String?   @map("cancel_reason") @db.VarChar(500)
  cancelTime           DateTime? @map("cancel_time")
  buyerRemark          String?   @map("buyer_remark") @db.VarChar(500)
  version              Int       @default(0)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user       User         @relation(fields: [userId], references: [id])
  items      OrderItem[]
  statusLogs OrderStatusLog[]

  @@index([userId, status])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id               BigInt   @id @default(autoincrement())
  orderId          BigInt   @map("order_id")
  orderNo          String   @map("order_no") @db.VarChar(32)
  productId        BigInt   @map("product_id")
  skuId            BigInt   @map("sku_id")
  productName      String   @map("product_name") @db.VarChar(200)
  productImageUrl  String?  @map("product_image_url") @db.VarChar(500)
  skuSpecSnapshot  Json?    @map("sku_spec_snapshot")
  price            Decimal  @db.Decimal(12, 2)
  quantity         Int
  totalAmount      Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  order Order      @relation(fields: [orderId], references: [id])
  sku   ProductSku @relation(fields: [skuId], references: [id])

  @@index([orderId])
  @@index([orderNo])
  @@map("order_items")
}

model OrderStatusLog {
  id           BigInt   @id @default(autoincrement())
  orderId      BigInt   @map("order_id")
  orderNo      String   @map("order_no") @db.VarChar(32)
  fromStatus   String?  @map("from_status") @db.VarChar(30)
  toStatus     String   @map("to_status") @db.VarChar(30)
  operatorId   BigInt?  @map("operator_id")
  operatorType String   @default("system") @map("operator_type") @db.VarChar(20)
  remark       String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_logs")
}

model UserAddress {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  receiverName  String    @map("receiver_name") @db.VarChar(50)
  receiverPhone String    @map("receiver_phone") @db.VarChar(20)
  province      String    @db.VarChar(50)
  provinceCode  String?   @map("province_code") @db.VarChar(20)
  city          String    @db.VarChar(50)
  cityCode      String?   @map("city_code") @db.VarChar(20)
  district      String    @db.VarChar(50)
  districtCode  String?   @map("district_code") @db.VarChar(20)
  detailAddress String    @map("detail_address") @db.VarChar(500)
  postalCode    String?   @map("postal_code") @db.VarChar(10)
  addressTag    String    @default("home") @map("address_tag") @db.VarChar(20)
  isDefault     Boolean   @default(false) @map("is_default")
  longitude     Decimal?  @db.Decimal(10, 7)
  latitude      Decimal?  @db.Decimal(10, 7)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_addresses")
}

model SignInRecord {
  id               BigInt   @id @default(autoincrement())
  userId           BigInt   @map("user_id")
  signDate         DateTime @map("sign_date") @db.Date
  consecutiveDays  Int      @default(1) @map("consecutive_days")
  pointsEarned     Int      @default(0) @map("points_earned")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, signDate])
  @@index([userId])
  @@map("sign_in_records")
}

model PointsAccount {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @unique @map("user_id")
  totalEarned   Int      @default(0) @map("total_earned")
  totalSpent    Int      @default(0) @map("total_spent")
  totalExpired  Int      @default(0) @map("total_expired")
  balance       Int      @default(0)
  frozenPoints  Int      @default(0) @map("frozen_points")
  version       Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("points_accounts")
}

model Banner {
  id        BigInt    @id @default(autoincrement())
  title     String    @db.VarChar(100)
  imageUrl  String    @map("image_url") @db.VarChar(500)
  linkType  String    @default("none") @map("link_type") @db.VarChar(20)
  linkValue String?   @map("link_value") @db.VarChar(500)
  position  String    @default("home") @db.VarChar(30)
  sortOrder Int       @default(0) @map("sort_order")
  isEnabled Boolean   @default(true) @map("is_enabled")
  startTime DateTime? @map("start_time")
  endTime   DateTime? @map("end_time")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([position, isEnabled])
  @@map("banners")
}

model Announcement {
  id         BigInt    @id @default(autoincrement())
  title      String    @db.VarChar(200)
  content    String    @db.Text
  type       String    @default("notice") @db.VarChar(20)
  isTop      Boolean   @default(false) @map("is_top")
  sortOrder  Int       @default(0) @map("sort_order")
  isEnabled  Boolean   @default(true) @map("is_enabled")
  publishTime DateTime? @map("publish_time")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([type, isEnabled])
  @@map("announcements")
}

model Navigation {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(50)
  iconUrl   String?  @map("icon_url") @db.VarChar(500)
  linkType  String   @default("none") @map("link_type") @db.VarChar(20)
  linkValue String?  @map("link_value") @db.VarChar(500)
  parentId  BigInt   @default(0) @map("parent_id")
  position  String   @default("home") @db.VarChar(30)
  sortOrder Int      @default(0) @map("sort_order")
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([position, isEnabled])
  @@map("navigations")
}
